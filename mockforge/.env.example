# MockForge environment example
# Copy this file to .env.local and fill in the values you actually need.

# --- Required for the current MVP ---
IMAGE_PROVIDER=fal
FAL_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- fal.ai models ---
# Default variant A model
FAL_MODEL=fal-ai/flux-kontext/dev

# Optional variant overrides
FAL_MODEL_A=fal-ai/flux-kontext/dev
FAL_MODEL_B=fal-ai/flux-pro/kontext
FAL_MODEL_C=fal-ai/gpt-image-1/edit-image

# --- Optional: Replicate fallback / experiments ---
REPLICATE_API_TOKEN=
REPLICATE_MODEL=black-forest-labs/flux-kontext-dev

# --- Supabase (optional — app works without it, generations won't be persisted) ---
# Also required for magic-link auth (NEXT_PUBLIC_SUPABASE_ANON_KEY).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Storage backend (default: local filesystem) ---
# Set to "supabase" once Supabase is configured (URL + service role key above).
# Both buckets must exist in your Supabase project (public access):
#   mockforge-inputs  — user-uploaded source images
#   mockforge-outputs — AI-generated output images
# Apply supabase/migrations/20260406000002_storage.sql to create them.
# If env vars are absent or a Supabase call fails, the app falls back to local automatically.
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=supabase

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs — create these in your Stripe dashboard under Products
STRIPE_PRICE_SINGLE_PACK=
STRIPE_PRICE_BUNDLE=

# Admin endpoint secret — used to call POST /api/admin/cleanup
CLEANUP_SECRET=

# --- Analytics (PostHog) ---
# Get your key at https://posthog.com — leave empty to disable analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
